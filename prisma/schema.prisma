generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Autenticación (Better Auth) ────────────────────────────────────────────
// Estos modelos siguen el schema que Better Auth espera. Sus IDs usan
// cuid() en vez de nuestro UlidIdGenerator: Better Auth administra estas
// tablas directamente a través de su adapter de Prisma, sin pasar por
// nuestros repositorios ni casos de uso -- no son un agregado de nuestro
// dominio, son infraestructura de un tercero.
model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  sessions Session[]
  accounts Account[]
  members  Member[]
  // El rol NO vive aquí -- vive en Member, porque en un sistema
  // multi-tenant el mismo usuario puede tener un rol distinto en cada
  // organización (ADMIN en la Empresa A, sin acceso en la Empresa B).

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  // A qué organización "está parado" el usuario en esta sesión -- todas
  // las queries de negocio se filtran por esta, no por "todas las
  // organizaciones a las que pertenece".
  activeOrganizationId String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  idToken      String?
  password     String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verification")
}

// ── Multi-tenancy (plugin organization) ────────────────────────────────────
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  members     Member[]
  invitations Invitation[]
  categories  Category[]
  brands      Brand[]
  products    Product[]
  stocks      Stock[]
  inventoryMovements InventoryMovement[]

  @@map("organization")
}

model Member {
  id   String @id @default(cuid())
  role String @default("member")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      String?
  status    String   @default("pending")
  expiresAt DateTime
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  inviterId String

  @@index([organizationId])
  @@map("invitation")
}

enum ProductType {
  PHYSICAL
  SERVICE
  DIGITAL
}

model Brand {
  id             String  @id
  organizationId String
  name           String
  description    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Mismo criterio que Category: el nombre se repite entre empresas, no
  // dentro de la misma.
  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([deletedAt])
}

model Category {
  id             String  @id
  organizationId String
  name           String
  description    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // "Electrónica" puede existir en dos empresas distintas -- lo que no
  // puede repetirse es el nombre DENTRO de la misma empresa.
  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([deletedAt])
}

model Product {
  id             String @id
  organizationId String

  sku     String
  barcode String?

  name        String
  description String?

  productType ProductType @default(PHYSICAL)

  costPrice Decimal @db.Decimal(12, 2)
  salePrice Decimal @db.Decimal(12, 2)

  trackInventory Boolean @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  stock              Stock?
  inventoryMovements InventoryMovement[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Mismo SKU puede repetirse entre empresas distintas, no dentro de la
  // misma. Igual para barcode (Postgres no cuenta NULL contra un unique
  // compuesto, así que varios productos sin barcode en la misma empresa
  // siguen siendo válidos).
  @@unique([organizationId, sku])
  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([name])
  @@index([productType])
  @@index([brandId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([deletedAt])
}

// ── Inventario ──────────────────────────────────────────────────────────
// Stock = cantidad ACTUAL de un producto (una fila por producto).
// InventoryMovement = historial INMUTABLE de cada cambio (el kardex).
// No son lo mismo que los domain events: los events alimentan auditoría
// (técnico), InventoryMovement es un dato de negocio que el usuario
// consulta directamente ("historial de este producto").
model Stock {
  id             String @id
  organizationId String
  productId      String @unique

  quantity Int @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

enum InventoryMovementReason {
  INITIAL // primera vez que se registra stock para un producto
  MANUAL_ADJUSTMENT // conteo físico, corrección manual
  SALE // (futuro) descontado por una venta
  PURCHASE // (futuro) agregado por una compra
  RETURN // (futuro) devolución de cliente o a proveedor
}

model InventoryMovement {
  id             String @id
  organizationId String
  productId      String

  // Con signo: positivo = entrada, negativo = salida. Un solo campo en
  // vez de (type + quantity) separados -- el signo YA dice si fue
  // entrada o salida, no hace falta duplicarlo en otro campo.
  quantityDelta Int
  reason        InventoryMovementReason
  note          String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([productId])
}
