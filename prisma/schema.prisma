generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProductType {
  PHYSICAL
  SERVICE
  DIGITAL
}

model Brand {
  id          String  @id
  name        String  @unique
  description String?

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Category {
  id          String  @id
  name        String  @unique
  description String?

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Product {
  id String @id

  sku     String  @unique
  barcode String? @unique

  name        String
  description String?

  productType ProductType @default(PHYSICAL)

  costPrice Decimal @db.Decimal(12, 2)
  salePrice Decimal @db.Decimal(12, 2)

  trackInventory Boolean @default(true)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([name])
  @@index([productType])
  @@index([brandId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([deletedAt])
}
