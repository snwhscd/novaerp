generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Autenticación (Better Auth) ────────────────────────────────────────────
// Estos modelos siguen el schema que Better Auth espera. Sus IDs usan
// cuid() en vez de nuestro UlidIdGenerator: Better Auth administra estas
// tablas directamente a través de su adapter de Prisma, sin pasar por
// nuestros repositorios ni casos de uso -- no son un agregado de nuestro
// dominio, son infraestructura de un tercero.
model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  sessions Session[]
  accounts Account[]
  members  Member[]
  // El rol NO vive aquí -- vive en Member, porque en un sistema
  // multi-tenant el mismo usuario puede tener un rol distinto en cada
  // organización (ADMIN en la Empresa A, sin acceso en la Empresa B).

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  // A qué organización "está parado" el usuario en esta sesión -- todas
  // las queries de negocio se filtran por esta, no por "todas las
  // organizaciones a las que pertenece".
  activeOrganizationId String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  idToken      String?
  password     String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verification")
}

// ── Multi-tenancy (plugin organization) ────────────────────────────────────
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  members     Member[]
  invitations Invitation[]

  @@map("organization")
}

model Member {
  id   String @id @default(cuid())
  role String @default("member")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      String?
  status    String   @default("pending")
  expiresAt DateTime
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  inviterId String

  @@index([organizationId])
  @@map("invitation")
}

enum ProductType {
  PHYSICAL
  SERVICE
  DIGITAL
}

model Brand {
  id          String  @id
  name        String  @unique
  description String?

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Category {
  id          String  @id
  name        String  @unique
  description String?

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Product {
  id String @id

  sku     String  @unique
  barcode String? @unique

  name        String
  description String?

  productType ProductType @default(PHYSICAL)

  costPrice Decimal @db.Decimal(12, 2)
  salePrice Decimal @db.Decimal(12, 2)

  trackInventory Boolean @default(true)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([name])
  @@index([productType])
  @@index([brandId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([deletedAt])
}
